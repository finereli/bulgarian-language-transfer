{
  "name": "hayde-bulgarian",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply hayde-db --local",
    "db:migrate": "wrangler d1 migrations apply hayde-db --remote",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.worker.json",
    "test": "node scripts/validate-content.mjs",
    "icons": "node scripts/make-icons.mjs"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250505.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.5.4",
    "vite": "^6.0.0",
    "wrangler": "^4.14.0"
  }
}
